<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E5DDD5"> <!-- Color de fondo típico de chats -->

    <!-- Barra Superior -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dog Messenger"
        android:background="@color/dog_blue"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:elevation="4dp" />

    <!-- Área de los mensajes (Scrollable) -->
    <ScrollView
        android:id="@+id/scrollViewChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:fillViewport="true">

        <TextView
            android:id="@+id/tvMensajes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#333333"
            android:text="=== Inicio de la conversación ===\n" />
    </ScrollView>

    <!-- Barra Inferior de envío de mensajes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <!-- Botón de Archivo (+) -->
        <Button
            android:id="@+id/btnEnviarArchivo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="+"
            android:textSize="24sp"
            android:backgroundTint="#78909C"
            android:textColor="@android:color/white"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="8dp" />

        <!-- Caja de Texto -->
        <EditText
            android:id="@+id/etMensaje"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Escribe un mensaje..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:background="@android:color/transparent"
            android:padding="12dp" />

        <!-- Botón Enviar -->
        <Button
            android:id="@+id/btnEnviarTexto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enviar"
            android:backgroundTint="@color/dog_blue"
            android:textColor="@android:color/white"
            android:layout_marginStart="8dp" />

    </LinearLayout>
</LinearLayout>